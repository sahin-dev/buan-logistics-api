model Invoice {
    id               String        @id @default(uuid())
    invoice_number   String        @unique
    amount           Float
    remaining_amount Float         @default(0.0)
    status           InvoiceStatus @default(PENDING)
    payment_type     PaymentType   @default(FULL)
    issued_at        DateTime      @default(now())
    due_at           DateTime
    shipmentId       String?
    shipment         Shipment?     @relation("SingleShipmentInvoice", fields: [shipmentId], references: [id], onDelete: Cascade)
    userId           String
    user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    payments         Payment[]
    
    // New relation for corporate bulk shipments
    shipments        Shipment[]    @relation("CorporateInvoiceShipments")

    createdAt        DateTime      @default(now())
    updatedAt        DateTime      @updatedAt

    @@map("invoices")
    @@index([id, invoice_number])
    @@index([userId])
    @@index([status])
    @@index([createdAt])
}

enum InvoiceStatus {
    PENDING
    PAID
    OVERDUE
    CANCELLED
}